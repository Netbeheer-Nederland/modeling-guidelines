grid-rows: 3
grid-columns: 3

vertical-gap: 80
horizontal-gap: 160

CE1: "Conducting Equipment 1" {class: [grid]}
T1: "Terminal 1" {class: [grid]}
1_3 {class:[empty]}


2_1 {class:[empty]}
